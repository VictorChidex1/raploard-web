# Firebase Functions — Environment Variables Template
# Copy this file to .env and fill in the real values.
# .env is gitignored — this template is safe to commit.

SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Find your Spotify Artist ID at:
# Spotify for Artists → Profile → the ID in the URL
SPOTIFY_ARTIST_ID=your_spotify_artist_id_here
