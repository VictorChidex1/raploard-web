rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    // Validates a basic email format: must contain @ and a domain extension
    function isValidEmail(email) {
      return email is string
          && email.size() >= 5
          && email.size() <= 254
          && email.matches('^[^@]+@[^@]+\\.[^@]+$');
    }

    // Prevents data bloat - checks a string is non-empty and within size bounds
    function isValidString(value, minLen, maxLen) {
      return value is string
          && value.size() >= minLen
          && value.size() <= maxLen;
    }

    // Ensures only the expected fields are submitted (no extra spam payload)
    function hasOnlyKeys(data, keys) {
      return data.keys().toSet() == keys.toSet();
    }

    // Returns true for any authenticated Firebase user.
    // The Firebase Console is the ONLY place to create users — no self-registration
    // exists on this site — making this effectively admin-only access.
    function isAdmin() {
      return request.auth != null;
    }

    match /newsletter/{document} {
      // Only allow document creation, never read/update/delete from the client
      allow create: if isValidEmail(request.resource.data.email)
                    // Allow only these 3 fields — nothing more, nothing less
                    && hasOnlyKeys(request.resource.data, ['email', 'timestamp', 'source'])
                    // Ensure 'source' is a recognized value, not arbitrary spam
                    && request.resource.data.source in ['website_footer', 'rsvp_modal']
                    // Timestamp must be the real server time — no fake entries
                    && request.resource.data.timestamp is timestamp;

      allow read: if isAdmin();       // Admin dashboard reads
      allow update, delete: if false;
    }


    // ─── Contacts Collection (Contact Form) ──────────────────────────────────
    match /contacts/{document} {
      allow create: if isValidEmail(request.resource.data.email)
                    // Only permit the exact 5 fields the form sends
                    && hasOnlyKeys(request.resource.data, ['name', 'email', 'subject', 'message', 'timestamp'])
                    // Name: 2–80 characters
                    && isValidString(request.resource.data.name, 2, 80)
                    // Message: 10–2000 characters (prevents one-word spam)
                    && isValidString(request.resource.data.message, 10, 2000)
                    // Subject must be one of the dropdown options only
                    && request.resource.data.subject in ['Booking Inquiry', 'Press / Media', 'Fan Mail']
                    // Timestamp must be the real server time — no forged dates
                    && request.resource.data.timestamp is timestamp;

      allow read: if isAdmin();       // Admin dashboard reads
      allow update, delete: if false;
    }


    // ─── Journal / Editorial Collection (CMS) ────────────────────────────────
    match /journal/{document} {
      allow read: if true;       // The public website must read to render the News feed
      allow write: if isAdmin(); // Only the Admin Dashboard can perform CMS actions (CRUD)
    }

     // Journal images can be read by anyone (public site) but only written by Admin.
    match /journal-covers/{imageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Deny anything else
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // ─── Integrations Collection (Spotify Synchronization Override) ────────────
    // The Spotify sync function writes to integrations/spotify every 24 hours.
    // The front-end needs to read this doc to power the embedded player.
    // can write here, as Admin SDK bypasses these rules entirely. However, the Admin
    // Dashboard also requires write access to push explicit Manual Overrides.
    match /integrations/{document} {
      allow read: if true;       // Public read — Spotify track IDs are not sensitive
      allow write: if isAdmin(); // Cloud Functions and Authenticated Admins may write
    }


    // ─── Default Rule: Everything Else Is Locked ────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
